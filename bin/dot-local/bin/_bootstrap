#!/usr/bin/env bash
set -euo pipefail

DOTFILES_REPO="git@github.com:geek4good/dotfiles.git"
DOTFILES_DIR="$HOME/Projects/GEEK4GOOD/dotfiles"

# Install Homebrew
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Install essential brew packages
echo "Installing brew packages..."
brew install \
    age \
    bat \
    fd \
    fnox \
    fzf \
    git \
    jq \
    lazygit \
    mise \
    neovim \
    stow \
    zoxide

# Clone dotfiles
if [ ! -d "$DOTFILES_DIR" ]; then
    echo "Cloning dotfiles..."
    mkdir -p "$(dirname "$DOTFILES_DIR")"
    git clone "$DOTFILES_REPO" "$DOTFILES_DIR"
fi

# Stow dotfiles
echo "Stowing dotfiles..."
"$DOTFILES_DIR/setup"

# Brew bundle (reads ~/.Brewfile created by stow)
echo "Installing Brewfile packages..."
brew bundle --global

# Touch ID for sudo (works inside tmux/zmx too)
if [[ "$(uname)" == "Darwin" ]]; then
    SUDO_LOCAL="/etc/pam.d/sudo_local"
    if ! grep -q pam_tid.so "$SUDO_LOCAL" 2>/dev/null; then
        echo "Configuring Touch ID for sudo..."
        sudo tee "$SUDO_LOCAL" >/dev/null <<'PAMSUDOEOF'
# sudo_local: local config file which survives system update and is included for sudo
auth       optional       pam_reattach.so
auth       sufficient     pam_tid.so
PAMSUDOEOF
    fi
fi

# Install mise tools (reads ~/.config/mise/config.toml created by stow)
echo "Installing mise tools..."
mise install

# Generate age identity for fnox
AGE_IDENTITY="$HOME/.config/fnox/age.txt"
DECRYPT_KEY="$HOME/.ssh/id_ed25519"
SSH_KEY="$HOME/.ssh/id_ed25519"
if [ ! -f "$AGE_IDENTITY" ] && [ -f "$SSH_KEY" ]; then
    echo "Generating age identity from SSH key..."
    mkdir -p "$(dirname "$AGE_IDENTITY")"
    ssh-to-age -private-key -i "$SSH_KEY" > "$AGE_IDENTITY"
    chmod 600 "$AGE_IDENTITY"
fi

# Provision secrets via age
if [ -d "$DOTFILES_DIR/secrets/encrypted" ] && [ -f "$DECRYPT_KEY" ]; then
    echo "Provisioning secrets..."

    # GPG keys
    age -d -i "$DECRYPT_KEY" "$DOTFILES_DIR/secrets/encrypted/gpg-private-keys.age" 2>/dev/null | gpg --import 2>/dev/null || true
    age -d -i "$DECRYPT_KEY" "$DOTFILES_DIR/secrets/encrypted/gpg-ownertrust.age" 2>/dev/null | gpg --import-ownertrust 2>/dev/null || true

    # Cloudflare tunnel credentials
    if [ -f "$DOTFILES_DIR/secrets/encrypted/cloudflared-creds.age" ]; then
        mkdir -p "$HOME/.cloudflared"
        age -d -i "$DECRYPT_KEY" "$DOTFILES_DIR/secrets/encrypted/cloudflared-creds.age" > "$HOME/.cloudflared/99877567-2599-4a31-a39d-cc2564eb9dad.json"
        chmod 600 "$HOME/.cloudflared/99877567-2599-4a31-a39d-cc2564eb9dad.json"
    fi
fi

echo "Done!"
